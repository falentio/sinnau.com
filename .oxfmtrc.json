{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"singleQuote": true,
	"trailingComma": "none",
	"printWidth": 100,
	"svelte": true,
	"sortImports": {
		"partitionByNewline": true,
		"newlinesBetween": false
	},
	"sortTailwindcss": {
		"stylesheet": "./src/routes/layout.css"
	},
	"sortPackageJson": false,
	"ignorePatterns": [
		"package-lock.json",
		"pnpm-lock.yaml",
		"yarn.lock",
		"bun.lock",
		"bun.lockb",
		".agents/",
		"/static/",
		"drizzle/",
		"src/lib/server/infras/db/schema/auth-schema.ts"
	]
}
