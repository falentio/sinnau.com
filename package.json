    "prepare": "svelte-kit sync || echo ''",
    "check": "ultracite check",
    "check:filter": "f() { svelte-kit sync && svelte-check --tsconfig ./tsconfig.json ${@:-.}; }; f",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "oxlint --type-aware",
    "lint:agent": "oxlint --type-aware -f agent",
    "lint:filter": "f() { p=\"${@:-.}\"; oxlint --type-aware $p; }; f",
    "format": "oxfmt",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run",
    "test:coverage": "vitest run --coverage",
    "auth:generate": "pnpm dlx @better-auth/cli@latest generate --config ./src/lib/server/infras/auth/index.ts --output ./src/lib/server/infras/db/schema/auth-schema.ts --yes",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "fix": "ultracite fix"
