  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "postbuild": "node scripts/patch-build.mjs",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo '' && (lefthook install || echo '')",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "oxlint --type-aware -c ./oxlint.config.ts",
    "lint:fix": "oxlint --fix --type-aware -c ./oxlint.config.ts",
    "lint:agent": "oxlint --type-aware -c ./oxlint.config.ts -f agent",
    "format": "oxfmt -c ./oxfmt.config.ts",
    "format:check": "oxfmt -c ./oxfmt.config.ts --check",
    "test:unit": "vitest",
    "test": "pnpm run test:unit -- --run",
    "test:coverage": "vitest run --coverage",
    "auth:generate": "better-auth generate --config ./src/lib/server/infras/auth/config.ts --output ./src/lib/server/infras/db/schema/auth-schema.ts --yes",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:check": "drizzle-kit check",
    "db:studio": "drizzle-kit studio",
    "opencode:serve": "portless oc2sin --app-port 11008 opencode serve --port 11008"
